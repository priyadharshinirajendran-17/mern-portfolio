# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/portfolio
# Atlas:  mongodb+srv://<username>:<password>@<cluster>.mongodb.net/portfolio
MONGO_URI=mongodb://127.0.0.1:27017/portfolio

# Port the Express server runs on
PORT=5000

# Comma separated list of allowed frontend origins (no trailing slash)
CLIENT_URL=http://localhost:5173

# Node environment: development | production
NODE_ENV=development
